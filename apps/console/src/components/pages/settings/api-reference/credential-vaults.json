[
  {
    "id": "vaults-list",
    "group": "Credential vaults",
    "title": "List vaults",
    "method": "GET",
    "path": "/v1/credential-vaults",
    "summary": "List credential vaults and summary counts without exposing secret values.",
    "response": [
      {
        "name": "data",
        "type": "CredentialVault[]",
        "description": "Credential vault descriptors."
      }
    ]
  },
  {
    "id": "vaults-create",
    "group": "Credential vaults",
    "title": "Create vault",
    "method": "POST",
    "path": "/v1/credential-vaults",
    "summary": "Create a vault for credentials that can be mounted into sessions.",
    "parameters": [
      {
        "name": "name",
        "type": "string",
        "required": true,
        "description": "Human-readable vault name."
      },
      {
        "name": "metadata",
        "type": "object",
        "description": "Opaque tags."
      }
    ],
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Vault identifier."
      },
      {
        "name": "vault",
        "type": "object",
        "description": "Created or updated vault resource."
      }
    ]
  },
  {
    "id": "vaults-get",
    "group": "Credential vaults",
    "title": "Get vault",
    "method": "GET",
    "path": "/v1/credential-vaults/{vault_id}",
    "summary": "Fetch a vault descriptor and safe credential summary.",
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Vault identifier."
      },
      {
        "name": "vault",
        "type": "object",
        "description": "Created or updated vault resource."
      }
    ]
  },
  {
    "id": "vaults-credentials-list",
    "group": "Credential vaults",
    "title": "List credentials",
    "method": "GET",
    "path": "/v1/credential-vaults/{vault_id}/credentials",
    "summary": "List credentials in a vault. Secret values are always masked or omitted.",
    "response": [
      {
        "name": "data",
        "type": "Credential[]",
        "description": "Safe credential descriptors."
      }
    ]
  },
  {
    "id": "vaults-credential-create",
    "group": "Credential vaults",
    "title": "Add credential",
    "method": "POST",
    "path": "/v1/credential-vaults/{vault_id}/credentials",
    "summary": "Add an OAuth, bearer token, or environment variable credential to a workspace vault.",
    "parameters": [
      {
        "name": "auth_type",
        "type": "mcp_oauth | bearer_token | environment_variable",
        "required": true,
        "description": "Credential type and injection mode."
      },
      {
        "name": "name",
        "type": "string",
        "description": "Optional human-readable label."
      },
      {
        "name": "value",
        "type": "string",
        "description": "Secret value. Stored encrypted and never returned in list responses."
      },
      {
        "name": "network",
        "type": "object",
        "description": "Allowed hosts and access mode for this credential."
      },
      {
        "name": "injection_locations",
        "type": "array",
        "description": "Request header or body injection locations."
      }
    ],
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Server-generated vcrd_... identifier."
      },
      {
        "name": "value_hint",
        "type": "string",
        "description": "Masked hint for the stored secret."
      },
      {
        "name": "status",
        "type": "active | archived",
        "description": "Current credential state."
      }
    ]
  },
  {
    "id": "vaults-credential-archive",
    "group": "Credential vaults",
    "title": "Archive credential",
    "method": "POST",
    "path": "/v1/credential-vaults/{vault_id}/credentials/{credential_id}/archive",
    "summary": "Archive a credential while retaining audit metadata.",
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Credential identifier."
      },
      {
        "name": "credential",
        "type": "object",
        "description": "Created or updated credential resource."
      }
    ]
  },
  {
    "id": "vaults-credential-delete",
    "group": "Credential vaults",
    "title": "Delete credential",
    "method": "DELETE",
    "path": "/v1/credential-vaults/{vault_id}/credentials/{credential_id}",
    "summary": "Delete a credential from a vault.",
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Credential identifier."
      },
      {
        "name": "credential",
        "type": "object",
        "description": "Created or updated credential resource."
      }
    ]
  },
  {
    "id": "vaults-archive",
    "group": "Credential vaults",
    "title": "Archive vault",
    "method": "POST",
    "path": "/v1/credential-vaults/{vault_id}/archive",
    "summary": "Archive a credential vault and remove it from active selection.",
    "response": [
      {
        "name": "id",
        "type": "string",
        "description": "Archived vault identifier."
      },
      {
        "name": "vault",
        "type": "object",
        "description": "Created or updated vault resource."
      }
    ]
  }
]
